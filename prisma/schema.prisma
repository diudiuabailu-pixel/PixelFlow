generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 用户系统 ====================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  avatarUrl     String?
  provider      String    @default("credentials") // credentials | google
  providerId    String?

  // 额度系统
  credits       Int       @default(50)
  plan          String    @default("free") // free | pro | pro_plus

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  generations   Generation[]
  sessions      Session[]
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== 项目系统 ====================

model Project {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  thumbnail   String   @default("")
  status      String   @default("draft") // draft | active | archived

  // 画布数据（JSON 序列化）
  canvasData  String   @default("{}") // { nodes: [], edges: [] }

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  generations Generation[]

  @@index([userId])
}

// ==================== 模板系统 ====================

model Template {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String
  thumbnail   String   @default("")
  models      String   // JSON array: ["FLUX.1", "SDXL"]
  tags        String   // JSON array: ["电商", "商品图"]
  canvasData  String   @default("{}") // 预置画布节点

  isOfficial  Boolean  @default(true)
  usageCount  Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== 生成记录 ====================

model Generation {
  id         String   @id @default(uuid())
  type       String   // image | video
  prompt     String
  model      String
  params     String   @default("{}") // JSON: { width, height, steps, seed, ... }

  status     String   @default("pending") // pending | running | success | failed
  outputUrl  String?
  errorMsg   String?
  creditCost Int      @default(0)

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
}
